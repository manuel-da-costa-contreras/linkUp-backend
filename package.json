{
  "name": "saas-dashboard-backend",
  "version": "1.0.0",
  "description": "Backend API for SaaS Dashboard",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/scripts/events/consume-watch.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "seed": "ts-node src/scripts/seed.ts",
    "auth:grant-org-role": "ts-node src/scripts/auth/grant-org-role.ts",
    "events:consume": "ts-node src/scripts/events/consume-once.ts",
    "events:consume:watch": "ts-node src/scripts/events/consume-watch.ts",
    "dev:ed:api": "powershell -NoProfile -Command \"$env:EVENT_PUBLISHER='firestore_outbox'; npm run dev\"",
    "dev:ed:consumer": "powershell -NoProfile -Command \"$env:EVENT_PROJECTION_MODE='apply'; npm run events:consume:watch\"",
    "dev:ed": "powershell -NoProfile -Command \"Start-Process powershell -ArgumentList '-NoExit','-NoProfile','-Command','$env:EVENT_PROJECTION_MODE=''''apply''''; npm run events:consume:watch'; $env:EVENT_PUBLISHER='firestore_outbox'; npm run dev\""
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.3",
    "@types/node": "^20.4.2",
    "@types/supertest": "^2.0.12",
    "jest": "^29.6.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "firebase-admin": "^11.10.1",
    "zod": "^4.3.6"
  }
}
